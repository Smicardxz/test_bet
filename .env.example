DATABASE_URL=postgresql://user:password@localhost:5432/betting_anomaly
REDIS_URL=redis://localhost:6379/0

# Data Provider Configuration
# Options: mock, api_football, sportmonks, apifootball, auto
# mock: Use synthetic data for testing
# api_football: Use API-Football / API-Sports (recommended)
# sportmonks: Use Sportmonks API
# apifootball: Use APIfootball.com
# auto: Try real data first, fallback to mock
DATA_PROVIDER=mock

# API-Football / API-Sports Configuration
API_FOOTBALL_KEY=your_api_key_here
API_FOOTBALL_URL=https://v3.football.api-sports.io

# Sportmonks Configuration
SPORTMONKS_KEY=your_api_key_here
SPORTMONKS_URL=https://api.sportmonks.com/v3

# APIfootball.com Configuration
APIFOOTBALL_KEY=your_api_key_here
APIFOOTBALL_URL=https://apiv3.apifootball.com

# Odds Provider Configuration
# Options: api_football, separate, mock
# api_football: Use odds from API-Football (if available)
# separate: Use dedicated odds API
# mock: Use synthetic odds
ODDS_PROVIDER=api_football
ODDS_API_KEY=your_api_key_here

# Cache Settings
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300

# Display Settings
SHOW_SOURCE_LABELS=true
WARN_ON_MOCK=true

LOG_LEVEL=INFO
ENVIRONMENT=development

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

MIN_MATCHES_FOR_STATS=5
ANOMALY_THRESHOLD=2.0
CONFIDENCE_HIGH_THRESHOLD=0.75
CONFIDENCE_MEDIUM_THRESHOLD=0.50

# ── Supabase (Phase persistence) ─────────────────────────────────────────────
# Trouvez ces valeurs dans : Supabase Dashboard → Project Settings → API
# Utilisez la clé "service_role" (bypasse RLS — backend uniquement)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-service-role-key-here

# ── EVENT_MODE Configuration ───────────────────────────────────────────────────
# Enable/disable EVENT_MODE features for international tournaments
# When true: automatic tagging of World Cup, Euro, friendlies, etc.
# When false: skip event tagging in main cycle
EVENT_MODE_ENABLED=true
